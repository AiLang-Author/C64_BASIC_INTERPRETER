// c64_basic_tui.ailang
// C64 BASIC Interpreter with TUI - Classic Blue Screen Experience
// Uses Library.TUI for full-screen terminal control
//
// Full featured interpreter with:
//   - Math: ABS, SGN, INT, SQR, RND, PEEK, POKE
//   - Strings: LEN, ASC, CHR$, LEFT$, RIGHT$, MID$, STR$, VAL
//   - File I/O: SAVE, LOAD
//   - Flow: GOTO, GOSUB, RETURN, FOR/NEXT, IF/THEN
//   - I/O: PRINT, INPUT, LIST, NEW, CLR, CLS, END

LibraryImport.XArrays
LibraryImport.TUI
LibraryImport.C64Math
LibraryImport.C64String
LibraryImport.C64FileIO

// =============================================================================
// C64 COLOR SCHEME
// =============================================================================
FixedPool.C64Colors {
    "BG_BLUE": Initialize=4       
    "FG_LIGHT_BLUE": Initialize=6  
    "FG_WHITE": Initialize=7       
    "BORDER": Initialize=4        
}

// =============================================================================
// SCREEN LAYOUT
// =============================================================================
FixedPool.Screen {
    "width": Initialize=80
    "height": Initialize=24
    "input_row": Initialize=23     
    "status_row": Initialize=24     
    "output_start": Initialize=3   
    "output_end": Initialize=22    
    "cursor_row": Initialize=3     
    "cursor_col": Initialize=1     
    "scroll_top": Initialize=3      
    "scroll_bottom": Initialize=22  
}

// =============================================================================
// INPUT BUFFER
// =============================================================================
FixedPool.InputBuf {
    "buffer_ptr": Initialize=0
    "pos": Initialize=0
    "max_len": Initialize=78
}

// =============================================================================
// BASIC STATE (same as before)
// =============================================================================
FixedPool.BState {
    "vars_ptr": Initialize=0
    "prog_nums_ptr": Initialize=0
    "prog_text_ptr": Initialize=0
    "gosub_stack_ptr": Initialize=0
    "gosub_sp": Initialize=0
    "for_var_ptr": Initialize=0
    "for_limit_ptr": Initialize=0
    "for_step_ptr": Initialize=0
    "for_line_ptr": Initialize=0
    "for_sp": Initialize=0
    "running": Initialize=0
    "current_idx": Initialize=0
    "current_line_num": Initialize=0
    "error_flag": Initialize=0
    "rng_seed": Initialize=12345
   
    "str_vars_ptr": Initialize=0
  
    "data_ptr": Initialize=0
    "data_line_idx": Initialize=0
    "data_pos": Initialize=0
}

FixedPool.Parser {
    "line_ptr": Initialize=0
    "pos": Initialize=0
    "line_len": Initialize=0
}

// =============================================================================
// C64 SCREEN OUTPUT FUNCTIONS
// =============================================================================

Function.C64_Init {
    Body: {
        TUI_Init()
        
        // Get actual screen size
        Screen.width = TUI_GetWidth()
        Screen.height = TUI_GetHeight()
        
        // Calculate layout based on screen size
        Screen.status_row = Screen.height
        Screen.input_row = Subtract(Screen.height, 1)
        Screen.output_end = Subtract(Screen.height, 2)
        Screen.scroll_bottom = Screen.output_end
        Screen.output_start = 3
        Screen.scroll_top = 3
        
        // Set C64 colors: light blue on dark blue
        TUI_SetColor(C64Colors.FG_LIGHT_BLUE, C64Colors.BG_BLUE)
        
        // Fill entire screen with blue background
        TUI_Fill(1, 1, Screen.height, Screen.width, 32)
        
        // Set up scroll region (ESC[top;bottom r)
        TUI_BufferChar(27)
        TUI_BufferChar(91)
        TUI_WriteNum(Screen.scroll_top)
        TUI_BufferChar(59)
        TUI_WriteNum(Screen.scroll_bottom)
        TUI_BufferChar(114)
        
        // Allocate input buffer
        InputBuf.buffer_ptr = Allocate(80)
        InputBuf.pos = 0
        
        // Initialize cursor position
        Screen.cursor_row = Screen.output_start
        Screen.cursor_col = 1
        
        TUI_Refresh()
    }
}

Function.C64_Shutdown {
    Body: {
        // Free input buffer
        IfCondition NotEqual(InputBuf.buffer_ptr, 0) ThenBlock: {
            Deallocate(InputBuf.buffer_ptr, 80)
            InputBuf.buffer_ptr = 0
        }
        
        // Cleanup libraries
        BCleanup()
        
        // Reset scroll region to full screen: ESC[r
        TUI_BufferChar(27)
        TUI_BufferChar(91)
        TUI_BufferChar(114)
        
        // Reset colors before leaving
        TUI_ResetColor()
        
        // Flush before shutdown
        TUI_Flush()
        
        // Properly shutdown TUI (restores terminal)
        TUI_Shutdown()
    }
}

// Print string at current cursor position with scrolling
Function.C64_Print {
    Input: str: Address
    Body: {
        i = 0
        len = StringLength(str)
        
        // Make sure we're in the scroll region with right colors
        TUI_SetColor(C64Colors.FG_LIGHT_BLUE, C64Colors.BG_BLUE)
        
        WhileLoop LessThan(i, len) {
            ch = GetByte(str, i)
            
            // Handle newline
            IfCondition EqualTo(ch, 10) ThenBlock: {
                Screen.cursor_col = 1
                Screen.cursor_row = Add(Screen.cursor_row, 1)
                C64_CheckScroll()
                TUI_MoveTo(Screen.cursor_row, Screen.cursor_col)
            } ElseBlock: {
                // Handle tab
                IfCondition EqualTo(ch, 9) ThenBlock: {
                    // Move to next tab stop (every 8 columns)
                    next_tab = Add(Screen.cursor_col, 8)
                    tab_mod = Modulo(Screen.cursor_col, 8)
                    spaces = Subtract(8, tab_mod)
                    Screen.cursor_col = Add(Screen.cursor_col, spaces)
                    IfCondition GreaterThan(Screen.cursor_col, Screen.width) ThenBlock: {
                        Screen.cursor_col = 1
                        Screen.cursor_row = Add(Screen.cursor_row, 1)
                        C64_CheckScroll()
                    }
                    TUI_MoveTo(Screen.cursor_row, Screen.cursor_col)
                } ElseBlock: {
                    // Print character
                    TUI_MoveTo(Screen.cursor_row, Screen.cursor_col)
                    TUI_PrintChar(ch)
                    Screen.cursor_col = Add(Screen.cursor_col, 1)
                    
                    // Wrap at end of line
                    IfCondition GreaterThan(Screen.cursor_col, Screen.width) ThenBlock: {
                        Screen.cursor_col = 1
                        Screen.cursor_row = Add(Screen.cursor_row, 1)
                        C64_CheckScroll()
                    }
                }
            }
            
            i = Add(i, 1)
        }
        
        TUI_Refresh()
    }
}

// Print number
Function.C64_PrintNum {
    Input: num: Integer
    Body: {
        TUI_MoveTo(Screen.cursor_row, Screen.cursor_col)
        TUI_PrintNum(num)
        
        // Estimate digits for cursor update
        n = num
        IfCondition LessThan(n, 0) ThenBlock: {
            n = Subtract(0, n)
            Screen.cursor_col = Add(Screen.cursor_col, 1)
        }
        IfCondition EqualTo(n, 0) ThenBlock: {
            Screen.cursor_col = Add(Screen.cursor_col, 1)
        } ElseBlock: {
            WhileLoop GreaterThan(n, 0) {
                Screen.cursor_col = Add(Screen.cursor_col, 1)
                n = Divide(n, 10)
            }
        }
        
        TUI_Refresh()
    }
}

// Print newline
Function.C64_NewLine {
    Body: {
        Screen.cursor_col = 1
        Screen.cursor_row = Add(Screen.cursor_row, 1)
        C64_CheckScroll()
        TUI_Refresh()
    }
}

// Scroll the output area up by one line
Function.C64_ScrollUp {
    Body: {
        // Move to bottom of scroll region
        TUI_MoveTo(Screen.scroll_bottom, 1)
        
        // Send scroll up command: ESC[S or just newline within scroll region
        // Using ESC[1S to scroll up 1 line
        TUI_BufferChar(27)
        TUI_BufferChar(91)
        TUI_BufferChar(49)  // 1
        TUI_BufferChar(83)  // S
        
        // Clear the new bottom line
        TUI_MoveTo(Screen.scroll_bottom, 1)
        TUI_SetColor(C64Colors.FG_LIGHT_BLUE, C64Colors.BG_BLUE)
        c = 0
        WhileLoop LessThan(c, Screen.width) {
            TUI_BufferChar(32)
            c = Add(c, 1)
        }
        
        TUI_Refresh()
    }
}

// Check if we need to scroll
Function.C64_CheckScroll {
    Body: {
        IfCondition GreaterThan(Screen.cursor_row, Screen.scroll_bottom) ThenBlock: {
            C64_ScrollUp()
            Screen.cursor_row = Screen.scroll_bottom
        }
    }
}

// Clear output area (within scroll region)
Function.C64_ClearOutput {
    Body: {
        TUI_SetColor(C64Colors.FG_LIGHT_BLUE, C64Colors.BG_BLUE)
        
        r = Screen.output_start
        WhileLoop LessEqual(r, Screen.output_end) {
            TUI_MoveTo(r, 1)
            c = 0
            WhileLoop LessThan(c, Screen.width) {
                TUI_PrintChar(32)
                c = Add(c, 1)
            }
            r = Add(r, 1)
        }
        Screen.cursor_row = Screen.output_start
        Screen.cursor_col = 1
        TUI_MoveTo(Screen.cursor_row, Screen.cursor_col)
        TUI_Refresh()
    }
}

// =============================================================================
// ERROR REPORTING
// =============================================================================
Function.C64_Error {
    Input: msg: Address
    Body: {
        C64_Print("?")
        C64_Print(msg)
        C64_Print(" ERROR")
        
        // Add line number if running a program
        IfCondition EqualTo(BState.running, 1) ThenBlock: {
            C64_Print(" IN ")
            C64_PrintNum(BState.current_line_num)
        }
        C64_NewLine()
        
        BState.error_flag = 1
        BState.running = 0
    }
}

// Draw the C64 boot screen header (outside scroll region)
Function.C64_DrawHeader {
    Body: {
        // Temporarily reset scroll region to draw header
        TUI_BufferChar(27)
        TUI_BufferChar(91)
        TUI_BufferChar(114)  // ESC[r - reset scroll region
        
        TUI_SetColor(C64Colors.FG_LIGHT_BLUE, C64Colors.BG_BLUE)
        
        // Center the header text
        TUI_MoveTo(1, 1)
        // Clear line first
        c = 0
        WhileLoop LessThan(c, Screen.width) {
            TUI_BufferChar(32)
            c = Add(c, 1)
        }
        TUI_MoveTo(1, 5)
        TUI_Print("**** COMMODORE 64 BASIC V2 ****")
        
        TUI_MoveTo(2, 1)
        // Clear line first
        c = 0
        WhileLoop LessThan(c, Screen.width) {
            TUI_BufferChar(32)
            c = Add(c, 1)
        }
        TUI_MoveTo(2, 2)
        TUI_Print("64K RAM SYSTEM  38911 BASIC BYTES FREE")
        
        // Restore scroll region
        TUI_BufferChar(27)
        TUI_BufferChar(91)
        TUI_WriteNum(Screen.scroll_top)
        TUI_BufferChar(59)
        TUI_WriteNum(Screen.scroll_bottom)
        TUI_BufferChar(114)
        
        TUI_Refresh()
    }
}

// Draw status bar at bottom
Function.C64_DrawStatus {
    Input: msg: Address
    Body: {
        TUI_SetColor(C64Colors.FG_WHITE, C64Colors.BG_BLUE)
        TUI_MoveTo(Screen.status_row, 1)
        
        // Clear status line
        c = 0
        WhileLoop LessThan(c, Screen.width) {
            TUI_PrintChar(32)
            c = Add(c, 1)
        }
        
        TUI_MoveTo(Screen.status_row, 1)
        TUI_Print(msg)
        
        TUI_SetColor(C64Colors.FG_LIGHT_BLUE, C64Colors.BG_BLUE)
        TUI_Refresh()
    }
}

// Draw input line with prompt
Function.C64_DrawInputLine {
    Body: {
        TUI_MoveTo(Screen.input_row, 1)
        
        // Clear input line
        c = 0
        WhileLoop LessThan(c, Screen.width) {
            TUI_PrintChar(32)
            c = Add(c, 1)
        }
        
        // Draw current input
        TUI_MoveTo(Screen.input_row, 1)
        i = 0
        WhileLoop LessThan(i, InputBuf.pos) {
            ch = GetByte(InputBuf.buffer_ptr, i)
            TUI_PrintChar(ch)
            i = Add(i, 1)
        }
        
        // Show cursor (blinking block would be ideal, but use underscore)
        TUI_PrintChar(95)  // _
        
        TUI_Refresh()
    }
}

// =============================================================================
// INPUT HANDLING
// =============================================================================

Function.C64_ReadLine {
    Output: Address
    Body: {
        InputBuf.pos = 0
        
        // Clear input buffer
        i = 0
        WhileLoop LessThan(i, 80) {
            SetByte(InputBuf.buffer_ptr, i, 0)
            i = Add(i, 1)
        }
        
        C64_DrawInputLine()
        
        done = 0
        WhileLoop EqualTo(done, 0) {
            key = TUI_GetKey()
            
            // Enter key
            IfCondition EqualTo(key, TUI_Keys.KEY_ENTER) ThenBlock: {
                done = 1
            } ElseBlock: {
                // Backspace
                IfCondition EqualTo(key, TUI_Keys.KEY_BACKSPACE) ThenBlock: {
                    IfCondition GreaterThan(InputBuf.pos, 0) ThenBlock: {
                        InputBuf.pos = Subtract(InputBuf.pos, 1)
                        SetByte(InputBuf.buffer_ptr, InputBuf.pos, 0)
                        C64_DrawInputLine()
                    }
                } ElseBlock: {
                    // ESC - check for quit
                    IfCondition EqualTo(key, TUI_Keys.KEY_ESC) ThenBlock: {
                        // Set special quit marker
                        SetByte(InputBuf.buffer_ptr, 0, 81)  // Q
                        SetByte(InputBuf.buffer_ptr, 1, 85)  // U
                        SetByte(InputBuf.buffer_ptr, 2, 73)  // I
                        SetByte(InputBuf.buffer_ptr, 3, 84)  // T
                        SetByte(InputBuf.buffer_ptr, 4, 0)
                        InputBuf.pos = 4
                        done = 1
                    } ElseBlock: {
                        // Regular character (printable ASCII 32-126)
                        IfCondition And(GreaterEqual(key, 32), LessEqual(key, 126)) ThenBlock: {
                            IfCondition LessThan(InputBuf.pos, InputBuf.max_len) ThenBlock: {
                                SetByte(InputBuf.buffer_ptr, InputBuf.pos, key)
                                InputBuf.pos = Add(InputBuf.pos, 1)
                                SetByte(InputBuf.buffer_ptr, InputBuf.pos, 0)
                                C64_DrawInputLine()
                            }
                        }
                    }
                }
            }
        }
        
        // Null terminate
        SetByte(InputBuf.buffer_ptr, InputBuf.pos, 0)
        
        // Copy to new buffer to return
        bufsize = Add(InputBuf.pos, 1)
        result = Allocate(bufsize)
        i = 0
        WhileLoop LessEqual(i, InputBuf.pos) {
            ch = GetByte(InputBuf.buffer_ptr, i)
            SetByte(result, i, ch)
            i = Add(i, 1)
        }
        
        // Echo input to output area
        C64_Print(result)
        C64_NewLine()
        
        ReturnValue(result)
    }
}

// =============================================================================
// BASIC INITIALIZATION
// =============================================================================
Function.BInit {
    Output: Integer
    Body: {
        // Numeric variables A-Z
        v = ArrayCreate(26)
        BState.vars_ptr = v
        i = 0
        WhileLoop LessThan(i, 26) {
            ArraySet(v, i, 0)
            i = Add(i, 1)
        }
        
        // String variables A$-Z$ (store pointers to strings)
        sv = ArrayCreate(26)
        BState.str_vars_ptr = sv
        i = 0
        WhileLoop LessThan(i, 26) {
            // Initialize with empty strings
            empty = Allocate(1)
            SetByte(empty, 0, 0)
            ArraySet(sv, i, empty)
            i = Add(i, 1)
        }
        
        // Program storage
        BState.prog_nums_ptr = XArray.XCreate(256)
        BState.prog_text_ptr = XArray.XCreate(256)
        
        // GOSUB stack
        BState.gosub_stack_ptr = ArrayCreate(32)
        BState.gosub_sp = 0
        
        // FOR stack
        BState.for_var_ptr = ArrayCreate(16)
        BState.for_limit_ptr = ArrayCreate(16)
        BState.for_step_ptr = ArrayCreate(16)
        BState.for_line_ptr = ArrayCreate(16)
        BState.for_sp = 0
        
        BState.running = 0
        BState.error_flag = 0
        BState.current_line_num = 0
        
        // DATA pointer
        BState.data_line_idx = 0
        BState.data_pos = 0
        
        // Initialize libraries
        C64FileIO.Init()
        
        ReturnValue(1)
    }
}

// Cleanup function
Function.BCleanup {
    Body: {
        // Free string variables
        sv = BState.str_vars_ptr
        IfCondition NotEqual(sv, 0) ThenBlock: {
            i = 0
            WhileLoop LessThan(i, 26) {
                str_ptr = ArrayGet(sv, i)
                IfCondition NotEqual(str_ptr, 0) ThenBlock: {
                    Deallocate(str_ptr, 0)
                }
                i = Add(i, 1)
            }
        }
        
        C64Math.Cleanup()
        C64FileIO.Cleanup()
    }
}

// =============================================================================
// STRING VARIABLE HELPERS
// =============================================================================

// Check if current position is a string variable (X$)
// Returns: variable index (0-25) if string var, -1 if not
Function.PCheckStringVar {
    Output: Integer
    Body: {
        IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
            ReturnValue(-1)
        }
        
        // First char must be a letter
        pcsv_ch = GetByte(Parser.line_ptr, Parser.pos)
        pcsv_isalpha = PIsAlpha(pcsv_ch)
        IfCondition EqualTo(pcsv_isalpha, 0) ThenBlock: {
            ReturnValue(-1)
        }
        
        // Skip over any additional alphanumeric characters
        pcsv_peek = Add(Parser.pos, 1)
        pcsv_done = 0
        WhileLoop And(LessThan(pcsv_peek, Parser.line_len), EqualTo(pcsv_done, 0)) {
            pcsv_peek_ch = GetByte(Parser.line_ptr, pcsv_peek)
            pcsv_peek_alpha = PIsAlpha(pcsv_peek_ch)
            pcsv_peek_digit = PIsDigit(pcsv_peek_ch)
            IfCondition Or(EqualTo(pcsv_peek_alpha, 1), EqualTo(pcsv_peek_digit, 1)) ThenBlock: {
                pcsv_peek = Add(pcsv_peek, 1)
            } ElseBlock: {
                pcsv_done = 1
            }
        }
        
        // Check if the character after the name is $
        IfCondition GreaterEqual(pcsv_peek, Parser.line_len) ThenBlock: {
            ReturnValue(-1)
        }
        
        pcsv_dollar = GetByte(Parser.line_ptr, pcsv_peek)
        IfCondition NotEqual(pcsv_dollar, 36) ThenBlock: {
            // Not a $ sign
            ReturnValue(-1)
        }
        
        // It's a string variable - return index based on first letter only
        pcsv_upper = PToUpper(pcsv_ch)
        pcsv_idx = Subtract(pcsv_upper, 65)
        ReturnValue(pcsv_idx)
    }
}

// Parse a string variable name (advances parser past X$)
Function.PParseStringVarName {
    Output: Integer
    Body: {
        // Get first letter for the index
        ppsv_ch = GetByte(Parser.line_ptr, Parser.pos)
        ppsv_upper = PToUpper(ppsv_ch)
        ppsv_idx = Subtract(ppsv_upper, 65)
        
        // Skip the first letter
        Parser.pos = Add(Parser.pos, 1)
        
        // Skip any additional alphanumeric characters
        ppsv_done = 0
        WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(ppsv_done, 0)) {
            ppsv_ch = GetByte(Parser.line_ptr, Parser.pos)
            ppsv_alpha = PIsAlpha(ppsv_ch)
            ppsv_digit = PIsDigit(ppsv_ch)
            IfCondition Or(EqualTo(ppsv_alpha, 1), EqualTo(ppsv_digit, 1)) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            } ElseBlock: {
                ppsv_done = 1
            }
        }
        
        // Skip the $ sign
        Parser.pos = Add(Parser.pos, 1)
        
        ReturnValue(ppsv_idx)
    }
}
// Get string variable value
Function.GetStringVar {
    Input: vidx: Integer
    Output: Address
    Body: {
        IfCondition Or(LessThan(vidx, 0), GreaterEqual(vidx, 26)) ThenBlock: {
            empty = Allocate(1)
            SetByte(empty, 0, 0)
            ReturnValue(empty)
        }
        
        sv = BState.str_vars_ptr
        str_ptr = ArrayGet(sv, vidx)
        
        // Return a copy
        len = StringLength(str_ptr)
        bufsize = Add(len, 1)
        copy = Allocate(bufsize)
        i = 0
        WhileLoop LessThan(i, len) {
            ch = GetByte(str_ptr, i)
            SetByte(copy, i, ch)
            i = Add(i, 1)
        }
        SetByte(copy, len, 0)
        
        ReturnValue(copy)
    }
}

// Set string variable value
Function.SetStringVar {
    Input: vidx: Integer
    Input: value: Address
    Body: {
        IfCondition Or(LessThan(vidx, 0), GreaterEqual(vidx, 26)) ThenBlock: {
            ReturnValue(0)
        }
        
        sv = BState.str_vars_ptr
        
        // Free old value
        old_str = ArrayGet(sv, vidx)
        IfCondition NotEqual(old_str, 0) ThenBlock: {
            Deallocate(old_str, 0)
        }
        
        // Copy new value
        len = StringLength(value)
        bufsize = Add(len, 1)
        new_str = Allocate(bufsize)
        i = 0
        WhileLoop LessThan(i, len) {
            ch = GetByte(value, i)
            SetByte(new_str, i, ch)
            i = Add(i, 1)
        }
        SetByte(new_str, len, 0)
        
        ArraySet(sv, vidx, new_str)
        ReturnValue(0)
    }
}

// =============================================================================
// STRING EXPRESSION PARSER
// =============================================================================

// Parse a single string term (literal, variable, or function)
Function.PStrTerm {
    Output: Address
    Body: {
        PSkipSpaces()
        
        IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
            pst_empty = Allocate(1)
            SetByte(pst_empty, 0, 0)
            ReturnValue(pst_empty)
        }
        
        pst_ch = GetByte(Parser.line_ptr, Parser.pos)
        
        // === String literal "..." ===
        IfCondition EqualTo(pst_ch, 34) ThenBlock: {
            pst_result = PParseStr()
            ReturnValue(pst_result)
        }
        
        // === Check for string variable A$ ===
        pst_svidx = PCheckStringVar()
        IfCondition GreaterEqual(pst_svidx, 0) ThenBlock: {
            PParseStringVarName()
            pst_result = GetStringVar(pst_svidx)
            ReturnValue(pst_result)
        }
        
        // === Check for string functions ===
        pst_isalpha = PIsAlpha(pst_ch)
        IfCondition EqualTo(pst_isalpha, 1) ThenBlock: {
            pst_save_pos = Parser.pos
            pst_word = ParseWord()
            
            // --- CHR$(n) ---
            pst_cmp = StringCompare(pst_word, "CHR$")
            IfCondition EqualTo(pst_cmp, 0) ThenBlock: {
                Deallocate(pst_word, 0)
                PSkipSpaces()
                pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(pst_ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pst_code = PExpr()
                    PSkipSpaces()
                    pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(pst_ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    pst_result = C64String.CHR(pst_code)
                    ReturnValue(pst_result)
                }
            }
            
            // --- STR$(n) ---
            pst_cmp = StringCompare(pst_word, "STR$")
            IfCondition EqualTo(pst_cmp, 0) ThenBlock: {
                Deallocate(pst_word, 0)
                PSkipSpaces()
                pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(pst_ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pst_num = PExpr()
                    PSkipSpaces()
                    pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(pst_ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    pst_result = C64String.STR(pst_num)
                    ReturnValue(pst_result)
                }
            }
            
            // --- LEFT$(s$, n) ---
            pst_cmp = StringCompare(pst_word, "LEFT$")
            IfCondition EqualTo(pst_cmp, 0) ThenBlock: {
                Deallocate(pst_word, 0)
                PSkipSpaces()
                pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(pst_ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pst_str_arg = PStrExpr()
                    PSkipSpaces()
                    pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(pst_ch, 44) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    pst_n_arg = PExpr()
                    PSkipSpaces()
                    pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(pst_ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    pst_result = C64String.LEFT(pst_str_arg, pst_n_arg)
                    Deallocate(pst_str_arg, 0)
                    ReturnValue(pst_result)
                }
            }
            
            // --- RIGHT$(s$, n) ---
            pst_cmp = StringCompare(pst_word, "RIGHT$")
            IfCondition EqualTo(pst_cmp, 0) ThenBlock: {
                Deallocate(pst_word, 0)
                PSkipSpaces()
                pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(pst_ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pst_str_arg = PStrExpr()
                    PSkipSpaces()
                    pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(pst_ch, 44) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    pst_n_arg = PExpr()
                    PSkipSpaces()
                    pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(pst_ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    pst_result = C64String.RIGHT(pst_str_arg, pst_n_arg)
                    Deallocate(pst_str_arg, 0)
                    ReturnValue(pst_result)
                }
            }
            
            // --- MID$(s$, start, len) ---
            pst_cmp = StringCompare(pst_word, "MID$")
            IfCondition EqualTo(pst_cmp, 0) ThenBlock: {
                Deallocate(pst_word, 0)
                PSkipSpaces()
                pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(pst_ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pst_str_arg = PStrExpr()
                    PSkipSpaces()
                    pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(pst_ch, 44) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    pst_start_arg = PExpr()
                    PSkipSpaces()
                    pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    // Length is optional
                    pst_len_arg = 255
                    IfCondition EqualTo(pst_ch, 44) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                        pst_len_arg = PExpr()
                        PSkipSpaces()
                        pst_ch = GetByte(Parser.line_ptr, Parser.pos)
                    }
                    IfCondition EqualTo(pst_ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    pst_result = C64String.MID(pst_str_arg, pst_start_arg, pst_len_arg)
                    Deallocate(pst_str_arg, 0)
                    ReturnValue(pst_result)
                }
            }
            
            // --- Not a recognized string function, restore position ---
            Deallocate(pst_word, 0)
            Parser.pos = pst_save_pos
        }
        
        // === Unknown - return empty string ===
        pst_empty = Allocate(1)
        SetByte(pst_empty, 0, 0)
        ReturnValue(pst_empty)
    }
}

// =============================================================================
// PStrExpr - Parse string expression with concatenation (+)
// =============================================================================
Function.PStrExpr {
    Output: Address
    Body: {
        // Get first string term
        pse_left = PStrTerm()
        
        // Check for concatenation operator(s)
        pse_done = 0
        WhileLoop EqualTo(pse_done, 0) {
            PSkipSpaces()
            
            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                pse_done = 1
            } ElseBlock: {
                pse_ch = GetByte(Parser.line_ptr, Parser.pos)
                
                // + operator for string concatenation
                IfCondition EqualTo(pse_ch, 43) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pse_right = PStrTerm()
                    
                    // Concatenate left + right
                    pse_new = C64String.CONCAT(pse_left, pse_right)
                    
                    // Free old strings
                    Deallocate(pse_left, 0)
                    Deallocate(pse_right, 0)
                    
                    // Result becomes new left
                    pse_left = pse_new
                } ElseBlock: {
                    // Not a + operator, we're done
                    pse_done = 1
                }
            }
        }
        
        ReturnValue(pse_left)
    }
}

// =============================================================================
// PARSER HELPERS (same as original)
// =============================================================================
Function.PSetLine {
    Input: line: Address
    Body: {
        Parser.line_ptr = line
        Parser.pos = 0
        Parser.line_len = StringLength(line)
    }
}

Function.PSkipSpaces {
    Body: {
        done = 0
        WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(done, 0)) {
            ch = GetByte(Parser.line_ptr, Parser.pos)
            IfCondition Or(EqualTo(ch, 32), EqualTo(ch, 9)) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            } ElseBlock: {
                done = 1
            }
        }
    }
}

Function.PIsDigit {
    Input: ch: Integer
    Output: Integer
    Body: {
        IfCondition And(GreaterEqual(ch, 48), LessEqual(ch, 57)) ThenBlock: {
            ReturnValue(1)
        }
        ReturnValue(0)
    }
}

Function.PIsAlpha {
    Input: ch: Integer
    Output: Integer
    Body: {
        IfCondition And(GreaterEqual(ch, 65), LessEqual(ch, 90)) ThenBlock: {
            ReturnValue(1)
        }
        IfCondition And(GreaterEqual(ch, 97), LessEqual(ch, 122)) ThenBlock: {
            ReturnValue(1)
        }
        ReturnValue(0)
    }
}

Function.PToUpper {
    Input: ch: Integer
    Output: Integer
    Body: {
        IfCondition And(GreaterEqual(ch, 97), LessEqual(ch, 122)) ThenBlock: {
            ReturnValue(Subtract(ch, 32))
        }
        ReturnValue(ch)
    }
}

Function.PParseNum {
    Output: Integer
    Body: {
        val = 0
        neg = 0
        
        ch = GetByte(Parser.line_ptr, Parser.pos)
        IfCondition EqualTo(ch, 45) ThenBlock: {
            neg = 1
            Parser.pos = Add(Parser.pos, 1)
        }
        
        done = 0
        WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(done, 0)) {
            ch = GetByte(Parser.line_ptr, Parser.pos)
            isdig = PIsDigit(ch)
            IfCondition EqualTo(isdig, 1) ThenBlock: {
                digit = Subtract(ch, 48)
                val = Multiply(val, 10)
                val = Add(val, digit)
                Parser.pos = Add(Parser.pos, 1)
            } ElseBlock: {
                done = 1
            }
        }
        
        IfCondition EqualTo(neg, 1) ThenBlock: {
            val = Subtract(0, val)
        }
        ReturnValue(val)
    }
}

Function.PParseStr {
    Output: Address
    Body: {
        // Skip opening quote
        Parser.pos = Add(Parser.pos, 1)
        pps_start = Parser.pos
        
        // Find closing quote
        pps_done = 0
        WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(pps_done, 0)) {
            pps_ch = GetByte(Parser.line_ptr, Parser.pos)
            IfCondition EqualTo(pps_ch, 34) ThenBlock: {
                pps_done = 1
            } ElseBlock: {
                Parser.pos = Add(Parser.pos, 1)
            }
        }
        
        // Calculate length and allocate
        pps_len = Subtract(Parser.pos, pps_start)
        pps_bufsize = Add(pps_len, 1)
        pps_str = Allocate(pps_bufsize)
        
        // Copy characters
        pps_i = 0
        WhileLoop LessThan(pps_i, pps_len) {
            pps_srcpos = Add(pps_start, pps_i)
            pps_ch = GetByte(Parser.line_ptr, pps_srcpos)
            SetByte(pps_str, pps_i, pps_ch)
            pps_i = Add(pps_i, 1)
        }
        
        // Null terminate
        SetByte(pps_str, pps_len, 0)
        
        // Skip closing quote
        Parser.pos = Add(Parser.pos, 1)
        
        ReturnValue(pps_str)
    }
}

// =============================================================================
// EXPRESSION PARSER
// =============================================================================
Function.PFactor {
    Output: Integer
    Body: {
        PSkipSpaces()
        
        IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
            ReturnValue(0)
        }
        
        ch = GetByte(Parser.line_ptr, Parser.pos)
        
        // Number
        isdig = PIsDigit(ch)
        IfCondition EqualTo(isdig, 1) ThenBlock: {
            ReturnValue(PParseNum())
        }
        
        // Negative number
        IfCondition EqualTo(ch, 45) ThenBlock: {
            npos = Add(Parser.pos, 1)
            IfCondition LessThan(npos, Parser.line_len) ThenBlock: {
                nch = GetByte(Parser.line_ptr, npos)
                ndig = PIsDigit(nch)
                IfCondition EqualTo(ndig, 1) ThenBlock: {
                    ReturnValue(PParseNum())
                }
            }
        }
        
        // Parentheses
        IfCondition EqualTo(ch, 40) ThenBlock: {
            Parser.pos = Add(Parser.pos, 1)
            val = PExpr()
            PSkipSpaces()
            IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 41) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                }
            }
            ReturnValue(val)
        }
        
        // Check for function or variable (starts with letter)
        isalph = PIsAlpha(ch)
        IfCondition EqualTo(isalph, 1) ThenBlock: {
            // Save position to check for functions
            save_pos = Parser.pos
            word = ParseWord()
            kw = MatchKW(word)
            Deallocate(word, 0)
            
            // Math functions (20-25)
            IfCondition EqualTo(kw, 20) ThenBlock: {
                // ABS(x)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    arg = PExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64Math.ABS(arg)
                    ReturnValue(result)
                }
            }
            
            IfCondition EqualTo(kw, 21) ThenBlock: {
                // SGN(x)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    arg = PExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64Math.SGN(arg)
                    ReturnValue(result)
                }
            }
            
            IfCondition EqualTo(kw, 22) ThenBlock: {
                // INT(x)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    arg = PExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64Math.INT(arg)
                    ReturnValue(result)
                }
            }
            
            IfCondition EqualTo(kw, 23) ThenBlock: {
                // SQR(x)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    arg = PExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64Math.SQR(arg)
                    ReturnValue(result)
                }
            }
            
            IfCondition EqualTo(kw, 24) ThenBlock: {
                // RND(x)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    arg = PExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64Math.RND(arg)
                    ReturnValue(result)
                }
            }
            
            IfCondition EqualTo(kw, 25) ThenBlock: {
                // PEEK(x)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    arg = PExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64Math.PEEK(arg)
                    ReturnValue(result)
                }
            }
            
            // String-to-number functions (30-32)
            IfCondition EqualTo(kw, 30) ThenBlock: {
                // LEN(s$)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    str = PStrExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64String.LEN(str)
                    Deallocate(str, 0)
                    ReturnValue(result)
                }
            }
            
            IfCondition EqualTo(kw, 31) ThenBlock: {
                // ASC(s$)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    str = PStrExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64String.ASC(str)
                    Deallocate(str, 0)
                    ReturnValue(result)
                }
            }
            
            IfCondition EqualTo(kw, 32) ThenBlock: {
                // VAL(s$)
                PSkipSpaces()
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 40) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    str = PStrExpr()
                    PSkipSpaces()
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 41) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    }
                    result = C64String.VAL(str)
                    Deallocate(str, 0)
                    ReturnValue(result)
                }
            }
            
            // Not a function - must be a variable
            // Reset position and read just the first letter
            Parser.pos = save_pos
            ch = GetByte(Parser.line_ptr, Parser.pos)
            uch = PToUpper(ch)
            vidx = Subtract(uch, 65)
            Parser.pos = Add(Parser.pos, 1)
            
            // Skip rest of variable name
            done = 0
            WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(done, 0)) {
                ch = GetByte(Parser.line_ptr, Parser.pos)
                isok = PIsAlpha(ch)
                IfCondition EqualTo(isok, 0) ThenBlock: {
                    isok = PIsDigit(ch)
                }
                IfCondition EqualTo(isok, 1) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                } ElseBlock: {
                    done = 1
                }
            }
            
            IfCondition And(GreaterEqual(vidx, 0), LessThan(vidx, 26)) ThenBlock: {
                vars_arr = BState.vars_ptr
                val = ArrayGet(vars_arr, vidx)
                ReturnValue(val)
            }
            ReturnValue(0)
        }
        
        ReturnValue(0)
    }
}

Function.PTerm {
    Output: Integer
    Body: {
        left = PFactor()
        
        done = 0
        WhileLoop EqualTo(done, 0) {
            PSkipSpaces()
            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                done = 1
            } ElseBlock: {
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 42) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    right = PFactor()
                    left = Multiply(left, right)
                } ElseBlock: {
                    IfCondition EqualTo(ch, 47) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                        right = PFactor()
                        IfCondition NotEqual(right, 0) ThenBlock: {
                            left = Divide(left, right)
                        }
                    } ElseBlock: {
                        done = 1
                    }
                }
            }
        }
        ReturnValue(left)
    }
}

Function.PExpr {
    Output: Integer
    Body: {
        left = PTerm()
        
        done = 0
        WhileLoop EqualTo(done, 0) {
            PSkipSpaces()
            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                done = 1
            } ElseBlock: {
                ch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(ch, 43) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    right = PTerm()
                    left = Add(left, right)
                } ElseBlock: {
                    IfCondition EqualTo(ch, 45) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                        right = PTerm()
                        left = Subtract(left, right)
                    } ElseBlock: {
                        done = 1
                    }
                }
            }
        }
        ReturnValue(left)
    }
}

// =============================================================================
// PCompare - Fixed to handle both numeric and string comparisons
// =============================================================================
// Replace the existing PCompare function in c64_basic_interpreter.ailang
// =============================================================================

Function.PCompare {
    Output: Integer
    Body: {
        PSkipSpaces()
        
        // Check if this is a string comparison
       
        pcmp_is_string = 0
        
        IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
            pcmp_ch = GetByte(Parser.line_ptr, Parser.pos)
            
            // Check for string literal
            IfCondition EqualTo(pcmp_ch, 34) ThenBlock: {
                pcmp_is_string = 1
            } ElseBlock: {
                // Check for string variable
                pcmp_svidx = PCheckStringVar()
                IfCondition GreaterEqual(pcmp_svidx, 0) ThenBlock: {
                    pcmp_is_string = 1
                } ElseBlock: {
                    // Check for string function (word ending in $)
                    pcmp_isalpha = PIsAlpha(pcmp_ch)
                    IfCondition EqualTo(pcmp_isalpha, 1) ThenBlock: {
                        pcmp_peek = Parser.pos
                        pcmp_peek_done = 0
                        WhileLoop And(LessThan(pcmp_peek, Parser.line_len), EqualTo(pcmp_peek_done, 0)) {
                            pcmp_peek_ch = GetByte(Parser.line_ptr, pcmp_peek)
                            pcmp_peek_alpha = PIsAlpha(pcmp_peek_ch)
                            IfCondition EqualTo(pcmp_peek_alpha, 1) ThenBlock: {
                                pcmp_peek = Add(pcmp_peek, 1)
                            } ElseBlock: {
                                pcmp_peek_done = 1
                            }
                        }
                        IfCondition LessThan(pcmp_peek, Parser.line_len) ThenBlock: {
                            pcmp_peek_ch = GetByte(Parser.line_ptr, pcmp_peek)
                            IfCondition EqualTo(pcmp_peek_ch, 36) ThenBlock: {
                                pcmp_is_string = 1
                            }
                        }
                    }
                }
            }
        }
        
        // Handle string comparison
        IfCondition EqualTo(pcmp_is_string, 1) ThenBlock: {
            pcmp_left_str = PStrExpr()
            PSkipSpaces()
            
            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                // No operator, just return if string is non-empty (truthy)
                pcmp_len = StringLength(pcmp_left_str)
                Deallocate(pcmp_left_str, 0)
                IfCondition GreaterThan(pcmp_len, 0) ThenBlock: {
                    ReturnValue(-1)
                }
                ReturnValue(0)
            }
            
            pcmp_op = GetByte(Parser.line_ptr, Parser.pos)
            
            // = operator
            IfCondition EqualTo(pcmp_op, 61) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
                pcmp_right_str = PStrExpr()
                pcmp_cmp = StringCompare(pcmp_left_str, pcmp_right_str)
                Deallocate(pcmp_left_str, 0)
                Deallocate(pcmp_right_str, 0)
                IfCondition EqualTo(pcmp_cmp, 0) ThenBlock: {
                    ReturnValue(-1)
                }
                ReturnValue(0)
            }
            
            // <> operator
            IfCondition EqualTo(pcmp_op, 60) ThenBlock: {
                pcmp_next_pos = Add(Parser.pos, 1)
                IfCondition LessThan(pcmp_next_pos, Parser.line_len) ThenBlock: {
                    pcmp_next_ch = GetByte(Parser.line_ptr, pcmp_next_pos)
                    IfCondition EqualTo(pcmp_next_ch, 62) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 2)
                        pcmp_right_str = PStrExpr()
                        pcmp_cmp = StringCompare(pcmp_left_str, pcmp_right_str)
                        Deallocate(pcmp_left_str, 0)
                        Deallocate(pcmp_right_str, 0)
                        IfCondition NotEqual(pcmp_cmp, 0) ThenBlock: {
                            ReturnValue(-1)
                        }
                        ReturnValue(0)
                    }
                }
            }
            
            // < operator (string comparison)
            IfCondition EqualTo(pcmp_op, 60) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
                pcmp_right_str = PStrExpr()
                pcmp_cmp = StringCompare(pcmp_left_str, pcmp_right_str)
                Deallocate(pcmp_left_str, 0)
                Deallocate(pcmp_right_str, 0)
                IfCondition LessThan(pcmp_cmp, 0) ThenBlock: {
                    ReturnValue(-1)
                }
                ReturnValue(0)
            }
            
            // > operator (string comparison)
            IfCondition EqualTo(pcmp_op, 62) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
                pcmp_right_str = PStrExpr()
                pcmp_cmp = StringCompare(pcmp_left_str, pcmp_right_str)
                Deallocate(pcmp_left_str, 0)
                Deallocate(pcmp_right_str, 0)
                IfCondition GreaterThan(pcmp_cmp, 0) ThenBlock: {
                    ReturnValue(-1)
                }
                ReturnValue(0)
            }
            
            // No valid operator found
            Deallocate(pcmp_left_str, 0)
            ReturnValue(0)
        }
        
        // Handle numeric comparison (original logic)
        pcmp_left = PExpr()
        PSkipSpaces()
        
        IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
            ReturnValue(pcmp_left)
        }
        
        pcmp_ch = GetByte(Parser.line_ptr, Parser.pos)
        
        // = 
        IfCondition EqualTo(pcmp_ch, 61) ThenBlock: {
            Parser.pos = Add(Parser.pos, 1)
            pcmp_right = PExpr()
            IfCondition EqualTo(pcmp_left, pcmp_right) ThenBlock: { ReturnValue(-1) }
            ReturnValue(0)
        }
        
        // < or <= or <>
        IfCondition EqualTo(pcmp_ch, 60) ThenBlock: {
            Parser.pos = Add(Parser.pos, 1)
            IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
                pcmp_nch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(pcmp_nch, 62) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pcmp_right = PExpr()
                    IfCondition NotEqual(pcmp_left, pcmp_right) ThenBlock: { ReturnValue(-1) }
                    ReturnValue(0)
                }
                IfCondition EqualTo(pcmp_nch, 61) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pcmp_right = PExpr()
                    IfCondition LessEqual(pcmp_left, pcmp_right) ThenBlock: { ReturnValue(-1) }
                    ReturnValue(0)
                }
            }
            pcmp_right = PExpr()
            IfCondition LessThan(pcmp_left, pcmp_right) ThenBlock: { ReturnValue(-1) }
            ReturnValue(0)
        }
        
        // > or >=
        IfCondition EqualTo(pcmp_ch, 62) ThenBlock: {
            Parser.pos = Add(Parser.pos, 1)
            IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
                pcmp_nch = GetByte(Parser.line_ptr, Parser.pos)
                IfCondition EqualTo(pcmp_nch, 61) ThenBlock: {
                    Parser.pos = Add(Parser.pos, 1)
                    pcmp_right = PExpr()
                    IfCondition GreaterEqual(pcmp_left, pcmp_right) ThenBlock: { ReturnValue(-1) }
                    ReturnValue(0)
                }
            }
            pcmp_right = PExpr()
            IfCondition GreaterThan(pcmp_left, pcmp_right) ThenBlock: { ReturnValue(-1) }
            ReturnValue(0)
        }
        
        ReturnValue(pcmp_left)
    }
}

// =============================================================================
// COMMANDS (Modified for TUI output)
// =============================================================================
Function.CmdPrint {
    Body: {
        print_newline = 1
        print_done = 0
        
        WhileLoop EqualTo(print_done, 0) {
            PSkipSpaces()
            
            // Check if we've reached end of line
            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                print_done = 1
            } ElseBlock: {
                print_ch = GetByte(Parser.line_ptr, Parser.pos)
                
                // === STRING LITERAL: "..." or "..."+"..." ===
                // Use PStrExpr to handle concatenation
                IfCondition EqualTo(print_ch, 34) ThenBlock: {
                    print_str = PStrExpr()
                    C64_Print(print_str)
                    Deallocate(print_str, 0)
                    print_newline = 1
                    
                // === SEMICOLON: suppress newline, no space ===
                } ElseBlock: {
                    IfCondition EqualTo(print_ch, 59) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                        print_newline = 0
                        
                    // === COMMA: tab to next column ===
                    } ElseBlock: {
                        IfCondition EqualTo(print_ch, 44) ThenBlock: {
                            Parser.pos = Add(Parser.pos, 1)
                            C64_Print("\t")
                            print_newline = 0
                            
                        // === COLON: end of this statement ===
                        } ElseBlock: {
                            IfCondition EqualTo(print_ch, 58) ThenBlock: {
                                print_done = 1
                                
                            // === Something else: variable, function, or expression ===
                            } ElseBlock: {
                                // First check: is it a string variable like A$ ?
                                print_svidx = PCheckStringVar()
                                IfCondition GreaterEqual(print_svidx, 0) ThenBlock: {
                                    // It's a string variable - use PStrExpr for possible concatenation
                                    print_str = PStrExpr()
                                    C64_Print(print_str)
                                    Deallocate(print_str, 0)
                                    print_newline = 1
                                } ElseBlock: {
                                    // Second check: is it a string function like LEFT$, CHR$, etc?
                                    print_is_strfunc = 0
                                    print_isalpha = PIsAlpha(print_ch)
                                    
                                    IfCondition EqualTo(print_isalpha, 1) ThenBlock: {
                                        // Peek ahead to see if word ends with $
                                        // Don't consume any input, just look
                                        print_peek = Parser.pos
                                        print_peek_done = 0
                                        
                                        // Skip over alphabetic characters
                                        WhileLoop And(LessThan(print_peek, Parser.line_len), EqualTo(print_peek_done, 0)) {
                                            print_peek_ch = GetByte(Parser.line_ptr, print_peek)
                                            print_peek_alpha = PIsAlpha(print_peek_ch)
                                            IfCondition EqualTo(print_peek_alpha, 1) ThenBlock: {
                                                print_peek = Add(print_peek, 1)
                                            } ElseBlock: {
                                                print_peek_done = 1
                                            }
                                        }
                                        
                                        // Check if the character after the word is $
                                        IfCondition LessThan(print_peek, Parser.line_len) ThenBlock: {
                                            print_peek_ch = GetByte(Parser.line_ptr, print_peek)
                                            IfCondition EqualTo(print_peek_ch, 36) ThenBlock: {
                                                // Yes, it's a string function (ends with $)
                                                print_is_strfunc = 1
                                            }
                                        }
                                    }
                                    
                                    // Now handle based on what we detected
                                    IfCondition EqualTo(print_is_strfunc, 1) ThenBlock: {
                                        // It's a string function - use PStrExpr for possible concatenation
                                        print_str = PStrExpr()
                                        C64_Print(print_str)
                                        Deallocate(print_str, 0)
                                        print_newline = 1
                                    } ElseBlock: {
                                        // It's a numeric expression
                                        print_val = PExpr()
                                        C64_PrintNum(print_val)
                                        print_newline = 1
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        
        // Print newline unless suppressed by semicolon
        IfCondition EqualTo(print_newline, 1) ThenBlock: {
            C64_NewLine()
        }
    }
}

Function.CmdLet {
    Body: {
        PSkipSpaces()
        
        // Check if it's a string variable
        svidx = PCheckStringVar()
        IfCondition GreaterEqual(svidx, 0) ThenBlock: {
            // String assignment: A$ = "value"
            PParseStringVarName()
            PSkipSpaces()
            ch = GetByte(Parser.line_ptr, Parser.pos)
            IfCondition EqualTo(ch, 61) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            }
            str_val = PStrExpr()
            SetStringVar(svidx, str_val)
            Deallocate(str_val, 0)
            ReturnValue(0)
        }
        
        // Numeric assignment
        lch = GetByte(Parser.line_ptr, Parser.pos)
        luch = PToUpper(lch)
        lvidx = Subtract(luch, 65)
        Parser.pos = Add(Parser.pos, 1)
        
        ldone = 0
        WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(ldone, 0)) {
            lc = GetByte(Parser.line_ptr, Parser.pos)
            lok = PIsAlpha(lc)
            IfCondition EqualTo(lok, 0) ThenBlock: {
                lok = PIsDigit(lc)
            }
            IfCondition EqualTo(lok, 1) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            } ElseBlock: {
                ldone = 1
            }
        }
        
        PSkipSpaces()
        lc = GetByte(Parser.line_ptr, Parser.pos)
        IfCondition EqualTo(lc, 61) ThenBlock: {
            Parser.pos = Add(Parser.pos, 1)
        }
        
        lval = PExpr()
        
        IfCondition And(GreaterEqual(lvidx, 0), LessThan(lvidx, 26)) ThenBlock: {
            ArraySet(BState.vars_ptr, lvidx, lval)
        }
    }
}

Function.CmdInput {
    Body: {
        PSkipSpaces()
        ch = GetByte(Parser.line_ptr, Parser.pos)
        
        // Optional prompt string
        IfCondition EqualTo(ch, 34) ThenBlock: {
            prompt = PParseStr()
            C64_Print(prompt)
            Deallocate(prompt, 0)
            PSkipSpaces()
            ch = GetByte(Parser.line_ptr, Parser.pos)
            IfCondition EqualTo(ch, 59) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            }
            IfCondition EqualTo(ch, 44) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            }
        } ElseBlock: {
            C64_Print("? ")
        }
        
        PSkipSpaces()
        
        // Check if it's a string variable
        svidx = PCheckStringVar()
        IfCondition GreaterEqual(svidx, 0) ThenBlock: {
            // String input
            PParseStringVarName()
            inp = C64_ReadLine()
            SetStringVar(svidx, inp)
            Deallocate(inp, 0)
            ReturnValue(0)
        }
        
        // Numeric input
        ch = GetByte(Parser.line_ptr, Parser.pos)
        uch = PToUpper(ch)
        vidx = Subtract(uch, 65)
        Parser.pos = Add(Parser.pos, 1)
        
        inp = C64_ReadLine()
        val = StringToNumber(inp)
        Deallocate(inp, 0)
        
        IfCondition And(GreaterEqual(vidx, 0), LessThan(vidx, 26)) ThenBlock: {
            ArraySet(BState.vars_ptr, vidx, val)
        }
    }
}

// =============================================================================
// KEYWORD MATCHING
// =============================================================================
Function.MatchKW {
    Input: word: Address
    Output: Integer
    Body: {
        // Core commands: 1-19
        c = StringCompare(word, "PRINT")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(1) }
        c = StringCompare(word, "LET")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(2) }
        c = StringCompare(word, "GOTO")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(3) }
        c = StringCompare(word, "GOSUB")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(4) }
        c = StringCompare(word, "RETURN")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(5) }
        c = StringCompare(word, "IF")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(6) }
        c = StringCompare(word, "THEN")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(7) }
        c = StringCompare(word, "FOR")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(8) }
        c = StringCompare(word, "TO")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(9) }
        c = StringCompare(word, "STEP")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(10) }
        c = StringCompare(word, "NEXT")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(11) }
        c = StringCompare(word, "INPUT")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(12) }
        c = StringCompare(word, "REM")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(13) }
        c = StringCompare(word, "END")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(14) }
        c = StringCompare(word, "LIST")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(15) }
        c = StringCompare(word, "RUN")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(16) }
        c = StringCompare(word, "NEW")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(17) }
        c = StringCompare(word, "CLR")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(18) }
        c = StringCompare(word, "CLS")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(19) }
        
        // Math functions: 20-29
        c = StringCompare(word, "ABS")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(20) }
        c = StringCompare(word, "SGN")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(21) }
        c = StringCompare(word, "INT")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(22) }
        c = StringCompare(word, "SQR")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(23) }
        c = StringCompare(word, "RND")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(24) }
        c = StringCompare(word, "PEEK")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(25) }
        
        // POKE is a statement, not function: 26
        c = StringCompare(word, "POKE")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(26) }
        
        // File I/O: 27-28
        c = StringCompare(word, "SAVE")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(27) }
        c = StringCompare(word, "LOAD")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(28) }
        
        // String functions: 30-39
        c = StringCompare(word, "LEN")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(30) }
        c = StringCompare(word, "ASC")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(31) }
        c = StringCompare(word, "VAL")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(32) }
        
        // DATA/READ/RESTORE: 40-42
        c = StringCompare(word, "DATA")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(40) }
        c = StringCompare(word, "READ")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(41) }
        c = StringCompare(word, "RESTORE")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(42) }
        
        // ON GOTO/GOSUB: 43
        c = StringCompare(word, "ON")
        IfCondition EqualTo(c, 0) ThenBlock: { ReturnValue(43) }
        
        ReturnValue(0)
    }
}

Function.ParseWord {
    Output: Address
    Body: {
        pw_start = Parser.pos
        
        // Consume alphanumeric characters
        pw_done = 0
        WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(pw_done, 0)) {
            pw_ch = GetByte(Parser.line_ptr, Parser.pos)
            pw_ok = PIsAlpha(pw_ch)
            IfCondition EqualTo(pw_ok, 0) ThenBlock: {
                pw_ok = PIsDigit(pw_ch)
            }
            IfCondition EqualTo(pw_ok, 1) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            } ElseBlock: {
                pw_done = 1
            }
        }
        
        // Check if next char is $ (for string functions like CHR$, LEFT$, etc.)
        IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
            pw_ch = GetByte(Parser.line_ptr, Parser.pos)
            IfCondition EqualTo(pw_ch, 36) ThenBlock: {
                // Include the $ in the word
                Parser.pos = Add(Parser.pos, 1)
            }
        }
        
        // Calculate word length and allocate
        pw_len = Subtract(Parser.pos, pw_start)
        pw_bufsize = Add(pw_len, 1)
        pw_word = Allocate(pw_bufsize)
        
        // Copy characters, converting to uppercase
        pw_i = 0
        WhileLoop LessThan(pw_i, pw_len) {
            pw_srcpos = Add(pw_start, pw_i)
            pw_ch = GetByte(Parser.line_ptr, pw_srcpos)
            pw_uch = PToUpper(pw_ch)
            SetByte(pw_word, pw_i, pw_uch)
            pw_i = Add(pw_i, 1)
        }
        SetByte(pw_word, pw_len, 0)
        
        ReturnValue(pw_word)
    }
}

// =============================================================================
// FIND LINE BY NUMBER
// =============================================================================
Function.FindLine {
    Input: num: Integer
    Output: Integer
    Body: {
        count = XArray.XSize(BState.prog_nums_ptr)
        i = 0
        WhileLoop LessThan(i, count) {
            n = XArray.XGet(BState.prog_nums_ptr, i)
            IfCondition EqualTo(n, num) ThenBlock: {
                ReturnValue(i)
            }
            i = Add(i, 1)
        }
        ReturnValue(-1)
    }
}

// =============================================================================
// GOTO / GOSUB / RETURN
// =============================================================================
Function.CmdGoto {
    Output: Integer
    Body: {
        target = PExpr()
        idx = FindLine(target)
        IfCondition EqualTo(idx, -1) ThenBlock: {
            C64_Print("?UNDEF'D STATEMENT ERROR\n")
            BState.error_flag = 1
            ReturnValue(-1)
        }
        BState.current_idx = idx
        ReturnValue(-2)
    }
}

Function.CmdGosub {
    Output: Integer
    Body: {
        sp = BState.gosub_sp
        IfCondition GreaterEqual(sp, 32) ThenBlock: {
            C64_Error("OUT OF MEMORY")
            ReturnValue(-1)
        }
        
        ArraySet(BState.gosub_stack_ptr, sp, Add(BState.current_idx, 1))
        BState.gosub_sp = Add(sp, 1)
        
        ReturnValue(CmdGoto())
    }
}

Function.CmdReturn {
    Output: Integer
    Body: {
        sp = BState.gosub_sp
        IfCondition EqualTo(sp, 0) ThenBlock: {
            C64_Error("RETURN WITHOUT GOSUB")
            ReturnValue(-1)
        }
        
        sp = Subtract(sp, 1)
        BState.gosub_sp = sp
        ret = ArrayGet(BState.gosub_stack_ptr, sp)
        BState.current_idx = ret
        ReturnValue(-2)
    }
}

// =============================================================================
// DATA/READ SUPPORT
// =============================================================================

// Find next DATA value in program
Function.FindNextData {
    Output: Address
    Body: {
        prog_count = XArray.XSize(BState.prog_nums_ptr)
        
        // Search from current data position
        WhileLoop LessThan(BState.data_line_idx, prog_count) {
            line_text = XArray.XGet(BState.prog_text_ptr, BState.data_line_idx)
            line_len = StringLength(line_text)
            
            // If at start of line, check if it's a DATA line
            IfCondition EqualTo(BState.data_pos, 0) ThenBlock: {
                // Skip leading spaces
                skip_sp = 1
                WhileLoop And(LessThan(BState.data_pos, line_len), EqualTo(skip_sp, 1)) {
                    ch = GetByte(line_text, BState.data_pos)
                    IfCondition Or(EqualTo(ch, 32), EqualTo(ch, 9)) ThenBlock: {
                        BState.data_pos = Add(BState.data_pos, 1)
                    } ElseBlock: {
                        skip_sp = 0
                    }
                }
                
                // Check for DATA keyword (need at least 4 chars)
                is_data = 0
                remaining = Subtract(line_len, BState.data_pos)
                IfCondition GreaterEqual(remaining, 4) ThenBlock: {
                    p1 = BState.data_pos
                    p2 = Add(p1, 1)
                    p3 = Add(p1, 2)
                    p4 = Add(p1, 3)
                    c1 = GetByte(line_text, p1)
                    c2 = GetByte(line_text, p2)
                    c3 = GetByte(line_text, p3)
                    c4 = GetByte(line_text, p4)
                    
                    // Convert to upper case
                    IfCondition And(GreaterEqual(c1, 97), LessEqual(c1, 122)) ThenBlock: {
                        c1 = Subtract(c1, 32)
                    }
                    IfCondition And(GreaterEqual(c2, 97), LessEqual(c2, 122)) ThenBlock: {
                        c2 = Subtract(c2, 32)
                    }
                    IfCondition And(GreaterEqual(c3, 97), LessEqual(c3, 122)) ThenBlock: {
                        c3 = Subtract(c3, 32)
                    }
                    IfCondition And(GreaterEqual(c4, 97), LessEqual(c4, 122)) ThenBlock: {
                        c4 = Subtract(c4, 32)
                    }
                    
                    // Check D-A-T-A (68-65-84-65)
                    IfCondition EqualTo(c1, 68) ThenBlock: {
                        IfCondition EqualTo(c2, 65) ThenBlock: {
                            IfCondition EqualTo(c3, 84) ThenBlock: {
                                IfCondition EqualTo(c4, 65) ThenBlock: {
                                    is_data = 1
                                    BState.data_pos = Add(BState.data_pos, 4)
                                }
                            }
                        }
                    }
                }
                
                IfCondition EqualTo(is_data, 0) ThenBlock: {
                    // Not a DATA line, move to next
                    BState.data_line_idx = Add(BState.data_line_idx, 1)
                    BState.data_pos = 0
                    ContinueLoop
                }
            }
            
            // Skip spaces
            skip_sp2 = 1
            WhileLoop And(LessThan(BState.data_pos, line_len), EqualTo(skip_sp2, 1)) {
                ch = GetByte(line_text, BState.data_pos)
                IfCondition Or(EqualTo(ch, 32), EqualTo(ch, 9)) ThenBlock: {
                    BState.data_pos = Add(BState.data_pos, 1)
                } ElseBlock: {
                    skip_sp2 = 0
                }
            }
            
            // Check for end of line
            IfCondition GreaterEqual(BState.data_pos, line_len) ThenBlock: {
                BState.data_line_idx = Add(BState.data_line_idx, 1)
                BState.data_pos = 0
                ContinueLoop
            }
            
            // Skip comma if present
            ch = GetByte(line_text, BState.data_pos)
            IfCondition EqualTo(ch, 44) ThenBlock: {
                BState.data_pos = Add(BState.data_pos, 1)
                // Skip spaces after comma
                skip_sp3 = 1
                WhileLoop And(LessThan(BState.data_pos, line_len), EqualTo(skip_sp3, 1)) {
                    ch = GetByte(line_text, BState.data_pos)
                    IfCondition Or(EqualTo(ch, 32), EqualTo(ch, 9)) ThenBlock: {
                        BState.data_pos = Add(BState.data_pos, 1)
                    } ElseBlock: {
                        skip_sp3 = 0
                    }
                }
            }
            
            // Check for end of line again after comma
            IfCondition GreaterEqual(BState.data_pos, line_len) ThenBlock: {
                BState.data_line_idx = Add(BState.data_line_idx, 1)
                BState.data_pos = 0
                ContinueLoop
            }
            
            // Now extract the data value
            ch = GetByte(line_text, BState.data_pos)
            
            // String value (quoted)
            IfCondition EqualTo(ch, 34) ThenBlock: {
                BState.data_pos = Add(BState.data_pos, 1)
                start = BState.data_pos
                find_quote = 1
                WhileLoop And(LessThan(BState.data_pos, line_len), EqualTo(find_quote, 1)) {
                    ch = GetByte(line_text, BState.data_pos)
                    IfCondition EqualTo(ch, 34) ThenBlock: {
                        find_quote = 0
                    } ElseBlock: {
                        BState.data_pos = Add(BState.data_pos, 1)
                    }
                }
                slen = Subtract(BState.data_pos, start)
                bufsize = Add(slen, 1)
                result = Allocate(bufsize)
                i = 0
                WhileLoop LessThan(i, slen) {
                    src_idx = Add(start, i)
                    ch = GetByte(line_text, src_idx)
                    SetByte(result, i, ch)
                    i = Add(i, 1)
                }
                SetByte(result, slen, 0)
                BState.data_pos = Add(BState.data_pos, 1)
                ReturnValue(result)
            }
            
            // Numeric or unquoted string value
            start = BState.data_pos
            find_end = 1
            WhileLoop And(LessThan(BState.data_pos, line_len), EqualTo(find_end, 1)) {
                ch = GetByte(line_text, BState.data_pos)
                IfCondition Or(EqualTo(ch, 44), EqualTo(ch, 58)) ThenBlock: {
                    find_end = 0
                } ElseBlock: {
                    BState.data_pos = Add(BState.data_pos, 1)
                }
            }
            
            // Trim trailing spaces
            end_pos = BState.data_pos
            trim_done = 0
            WhileLoop And(GreaterThan(end_pos, start), EqualTo(trim_done, 0)) {
                prev = Subtract(end_pos, 1)
                ch = GetByte(line_text, prev)
                IfCondition Or(EqualTo(ch, 32), EqualTo(ch, 9)) ThenBlock: {
                    end_pos = prev
                } ElseBlock: {
                    trim_done = 1
                }
            }
            
            slen = Subtract(end_pos, start)
            bufsize = Add(slen, 1)
            result = Allocate(bufsize)
            i = 0
            WhileLoop LessThan(i, slen) {
                src_idx = Add(start, i)
                ch = GetByte(line_text, src_idx)
                SetByte(result, i, ch)
                i = Add(i, 1)
            }
            SetByte(result, slen, 0)
            ReturnValue(result)
        }
        
        // No more DATA
        ReturnValue(0)
    }
}

// READ command
Function.CmdRead {
    Body: {
        read_done = 0
        WhileLoop EqualTo(read_done, 0) {
            PSkipSpaces()
            
            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                read_done = 1
            } ElseBlock: {
                ch = GetByte(Parser.line_ptr, Parser.pos)
                
                // Check for string variable
                svidx = PCheckStringVar()
                IfCondition GreaterEqual(svidx, 0) ThenBlock: {
                    PParseStringVarName()
                    data_val = FindNextData()
                    IfCondition EqualTo(data_val, 0) ThenBlock: {
                        C64_Error("OUT OF DATA")
                        ReturnValue(0)
                    }
                    SetStringVar(svidx, data_val)
                    Deallocate(data_val, 0)
                } ElseBlock: {
                    // Numeric variable
                    isalph = PIsAlpha(ch)
                    IfCondition EqualTo(isalph, 1) ThenBlock: {
                        uch = PToUpper(ch)
                        vidx = Subtract(uch, 65)
                        Parser.pos = Add(Parser.pos, 1)
                        
                        // Skip rest of variable name
                        skip_name = 1
                        WhileLoop EqualTo(skip_name, 1) {
                            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                                skip_name = 0
                            } ElseBlock: {
                                ch = GetByte(Parser.line_ptr, Parser.pos)
                                isok = PIsAlpha(ch)
                                IfCondition EqualTo(isok, 0) ThenBlock: {
                                    isok = PIsDigit(ch)
                                }
                                IfCondition EqualTo(isok, 1) ThenBlock: {
                                    Parser.pos = Add(Parser.pos, 1)
                                } ElseBlock: {
                                    skip_name = 0
                                }
                            }
                        }
                        
                        data_val = FindNextData()
                        IfCondition EqualTo(data_val, 0) ThenBlock: {
                            C64_Error("OUT OF DATA")
                            ReturnValue(0)
                        }
                        num_val = StringToNumber(data_val)
                        Deallocate(data_val, 0)
                        
                        IfCondition And(GreaterEqual(vidx, 0), LessThan(vidx, 26)) ThenBlock: {
                            ArraySet(BState.vars_ptr, vidx, num_val)
                        }
                    } ElseBlock: {
                        read_done = 1
                    }
                }
                
                // Check for comma (more variables)
                PSkipSpaces()
                IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 44) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    } ElseBlock: {
                        read_done = 1
                    }
                }
            }
        }
    }
}

// =============================================================================
// ON x GOTO/GOSUB
// =============================================================================
Function.CmdOn {
    Output: Integer
    Body: {
        // Parse the index expression
        idx = PExpr()
        
        PSkipSpaces()
        word = ParseWord()
        
        is_gosub = 0
        cmp = StringCompare(word, "GOSUB")
        IfCondition EqualTo(cmp, 0) ThenBlock: {
            is_gosub = 1
        }
        Deallocate(word, 0)
        
        // Parse line numbers
        line_nums = ArrayCreate(20)
        line_count = 0
        
        parse_lines = 1
        WhileLoop EqualTo(parse_lines, 1) {
            PSkipSpaces()
            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                parse_lines = 0
            } ElseBlock: {
                ch = GetByte(Parser.line_ptr, Parser.pos)
                isdig = PIsDigit(ch)
                IfCondition EqualTo(isdig, 1) ThenBlock: {
                    line_num = PParseNum()
                    ArraySet(line_nums, line_count, line_num)
                    line_count = Add(line_count, 1)
                    
                    PSkipSpaces()
                    IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
                        ch = GetByte(Parser.line_ptr, Parser.pos)
                        IfCondition EqualTo(ch, 44) ThenBlock: {
                            Parser.pos = Add(Parser.pos, 1)
                        } ElseBlock: {
                            parse_lines = 0
                        }
                    }
                } ElseBlock: {
                    parse_lines = 0
                }
            }
        }
        
        // Check if index is valid (1-based)
        IfCondition Or(LessThan(idx, 1), GreaterThan(idx, line_count)) ThenBlock: {
            ArrayDestroy(line_nums)
            ReturnValue(0)
        }
        
        // Get target line number
        arr_idx = Subtract(idx, 1)
        target = ArrayGet(line_nums, arr_idx)
        ArrayDestroy(line_nums)
        
        // Find line index
        line_idx = FindLine(target)
        IfCondition EqualTo(line_idx, -1) ThenBlock: {
            C64_Error("UNDEF'D STATEMENT")
            ReturnValue(-1)
        }
        
        // GOSUB needs to push return address
        IfCondition EqualTo(is_gosub, 1) ThenBlock: {
            sp = BState.gosub_sp
            IfCondition GreaterEqual(sp, 32) ThenBlock: {
                C64_Error("OUT OF MEMORY")
                ReturnValue(-1)
            }
            next_idx = Add(BState.current_idx, 1)
            ArraySet(BState.gosub_stack_ptr, sp, next_idx)
            BState.gosub_sp = Add(sp, 1)
        }
        
        BState.current_idx = line_idx
        ReturnValue(-2)
    }
}


// =============================================================================
// IF/THEN
// =============================================================================
Function.CmdIf {
    Output: Integer
    Body: {
        cond = PCompare()
        
        PSkipSpaces()
        word = ParseWord()
        Deallocate(word, 0)
        
        IfCondition EqualTo(cond, 0) ThenBlock: {
            Parser.pos = Parser.line_len
            ReturnValue(0)
        }
        
        PSkipSpaces()
        IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
            ch = GetByte(Parser.line_ptr, Parser.pos)
            isdig = PIsDigit(ch)
            IfCondition EqualTo(isdig, 1) ThenBlock: {
                ReturnValue(CmdGoto())
            }
        }
        
        ReturnValue(ExecStmt())
    }
}

// =============================================================================
// FOR/NEXT
// =============================================================================
Function.CmdFor {
    Body: {
        PSkipSpaces()
        ch = GetByte(Parser.line_ptr, Parser.pos)
        uch = PToUpper(ch)
        vidx = Subtract(uch, 65)
        Parser.pos = Add(Parser.pos, 1)
        
        fdone = 0
        WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(fdone, 0)) {
            fch = GetByte(Parser.line_ptr, Parser.pos)
            fisalph = PIsAlpha(fch)
            IfCondition EqualTo(fisalph, 0) ThenBlock: {
                fisalph = PIsDigit(fch)
            }
            IfCondition EqualTo(fisalph, 1) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            } ElseBlock: {
                fdone = 1
            }
        }
        
        PSkipSpaces()
        ch = GetByte(Parser.line_ptr, Parser.pos)
        IfCondition EqualTo(ch, 61) ThenBlock: {
            Parser.pos = Add(Parser.pos, 1)
        }
        
        init = PExpr()
        
        IfCondition And(GreaterEqual(vidx, 0), LessThan(vidx, 26)) ThenBlock: {
            ArraySet(BState.vars_ptr, vidx, init)
        }
        
        PSkipSpaces()
        toword = ParseWord()
        Deallocate(toword, 0)
        
        limit = PExpr()
        
        step = 1
        PSkipSpaces()
        IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
            stepsave = Parser.pos
            stepword = ParseWord()
            stepkw = MatchKW(stepword)
            Deallocate(stepword, 0)
            IfCondition EqualTo(stepkw, 10) ThenBlock: {
                step = PExpr()
            } ElseBlock: {
                Parser.pos = stepsave
            }
        }
        
        fsp = BState.for_sp
        IfCondition LessThan(fsp, 16) ThenBlock: {
            for_var_arr = BState.for_var_ptr
            for_limit_arr = BState.for_limit_ptr
            for_step_arr = BState.for_step_ptr
            for_line_arr = BState.for_line_ptr
            
            ArraySet(for_var_arr, fsp, vidx)
            ArraySet(for_limit_arr, fsp, limit)
            ArraySet(for_step_arr, fsp, step)
            // Store the NEXT line to jump to (line after FOR)
            next_line = Add(BState.current_idx, 1)
            ArraySet(for_line_arr, fsp, next_line)
            BState.for_sp = Add(fsp, 1)
        }
    }
}

Function.CmdNext {
    Output: Integer
    Body: {
        nsp = BState.for_sp
        IfCondition EqualTo(nsp, 0) ThenBlock: {
            C64_Error("NEXT WITHOUT FOR")
            ReturnValue(-1)
        }
        
        nsp = Subtract(nsp, 1)
        
        // Read FOR stack - avoid any nested calls
        for_var_arr = BState.for_var_ptr
        for_limit_arr = BState.for_limit_ptr
        for_step_arr = BState.for_step_ptr
        for_line_arr = BState.for_line_ptr
        vars_arr = BState.vars_ptr
        
        nvidx = ArrayGet(for_var_arr, nsp)
        nlimit = ArrayGet(for_limit_arr, nsp)
        nstep = ArrayGet(for_step_arr, nsp)
        nloopln = ArrayGet(for_line_arr, nsp)
        
        // Get current value and increment
        ncur = ArrayGet(vars_arr, nvidx)
        ncur = Add(ncur, nstep)
        ArraySet(vars_arr, nvidx, ncur)
        
        nisdone = 0
        IfCondition GreaterThan(nstep, 0) ThenBlock: {
            IfCondition GreaterThan(ncur, nlimit) ThenBlock: {
                nisdone = 1
            }
        } ElseBlock: {
            IfCondition LessThan(ncur, nlimit) ThenBlock: {
                nisdone = 1
            }
        }
        
        IfCondition EqualTo(nisdone, 1) ThenBlock: {
            BState.for_sp = nsp
            ReturnValue(0)
        }
        
        BState.for_sp = Add(nsp, 1)
        BState.current_idx = nloopln
        ReturnValue(-2)
    }
}

// =============================================================================
// LIST
// =============================================================================
Function.CmdList {
    Body: {
        count = XArray.XSize(BState.prog_nums_ptr)
        i = 0
        WhileLoop LessThan(i, count) {
            num = XArray.XGet(BState.prog_nums_ptr, i)
            txt = XArray.XGet(BState.prog_text_ptr, i)
            C64_PrintNum(num)
            C64_Print(" ")
            C64_Print(txt)
            C64_NewLine()
            i = Add(i, 1)
        }
    }
}

// =============================================================================
// RUN
// =============================================================================
Function.CmdRun {
    Body: {
        BState.running = 1
        BState.current_idx = 0
        BState.error_flag = 0
        BState.current_line_num = 0
        
        // Reset DATA pointer
        BState.data_line_idx = 0
        BState.data_pos = 0
        
        // Clear numeric variables
        i = 0
        WhileLoop LessThan(i, 26) {
            ArraySet(BState.vars_ptr, i, 0)
            i = Add(i, 1)
        }
        
        // Clear string variables
        sv = BState.str_vars_ptr
        i = 0
        WhileLoop LessThan(i, 26) {
            old_str = ArrayGet(sv, i)
            IfCondition NotEqual(old_str, 0) ThenBlock: {
                Deallocate(old_str, 0)
            }
            empty = Allocate(1)
            SetByte(empty, 0, 0)
            ArraySet(sv, i, empty)
            i = Add(i, 1)
        }
        
        BState.gosub_sp = 0
        BState.for_sp = 0
        
        count = XArray.XSize(BState.prog_nums_ptr)
        
        done = 0
        WhileLoop And(EqualTo(BState.running, 1), EqualTo(done, 0)) {
            IfCondition GreaterEqual(BState.current_idx, count) ThenBlock: {
                done = 1
            } ElseBlock: {
                // Get current line number for error reporting
                BState.current_line_num = XArray.XGet(BState.prog_nums_ptr, BState.current_idx)
                
                txt = XArray.XGet(BState.prog_text_ptr, BState.current_idx)
                old = BState.current_idx
                
                ExecLine(txt)
                
                IfCondition EqualTo(BState.current_idx, old) ThenBlock: {
                    BState.current_idx = Add(BState.current_idx, 1)
                }
                
                IfCondition EqualTo(BState.error_flag, 1) ThenBlock: {
                    BState.running = 0
                }
            }
        }
        
        IfCondition EqualTo(BState.error_flag, 0) ThenBlock: {
            C64_NewLine()
            C64_Print("READY.")
            C64_NewLine()
        }
    }
}

// =============================================================================
// NEW
// =============================================================================
Function.CmdNew {
    Body: {
        count = XArray.XSize(BState.prog_nums_ptr)
        i = 0
        WhileLoop LessThan(i, count) {
            txt = XArray.XGet(BState.prog_text_ptr, i)
            Deallocate(txt, 0)
            i = Add(i, 1)
        }
        XArray.XClear(BState.prog_nums_ptr)
        XArray.XClear(BState.prog_text_ptr)
        
        i = 0
        WhileLoop LessThan(i, 26) {
            ArraySet(BState.vars_ptr, i, 0)
            i = Add(i, 1)
        }
    }
}

// =============================================================================
// EXECUTE STATEMENT
// =============================================================================
Function.ExecStmt {
    Output: Integer
    Body: {
        PSkipSpaces()
        
        IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
            ReturnValue(0)
        }
        
        ech = GetByte(Parser.line_ptr, Parser.pos)
        eisalph = PIsAlpha(ech)
        
        IfCondition EqualTo(eisalph, 0) ThenBlock: {
            ReturnValue(0)
        }
        
        esave = Parser.pos
        eword = ParseWord()
        ekw = MatchKW(eword)
        Deallocate(eword, 0)
        
        IfCondition EqualTo(ekw, 1) ThenBlock: { CmdPrint() ReturnValue(0) }
        IfCondition EqualTo(ekw, 2) ThenBlock: { CmdLet() ReturnValue(0) }
        IfCondition EqualTo(ekw, 3) ThenBlock: { ReturnValue(CmdGoto()) }
        IfCondition EqualTo(ekw, 4) ThenBlock: { ReturnValue(CmdGosub()) }
        IfCondition EqualTo(ekw, 5) ThenBlock: { ReturnValue(CmdReturn()) }
        IfCondition EqualTo(ekw, 6) ThenBlock: { ReturnValue(CmdIf()) }
        IfCondition EqualTo(ekw, 8) ThenBlock: { CmdFor() ReturnValue(0) }
        IfCondition EqualTo(ekw, 11) ThenBlock: { ReturnValue(CmdNext()) }
        IfCondition EqualTo(ekw, 12) ThenBlock: { CmdInput() ReturnValue(0) }
        IfCondition EqualTo(ekw, 13) ThenBlock: { Parser.pos = Parser.line_len ReturnValue(0) }
        IfCondition EqualTo(ekw, 14) ThenBlock: { BState.running = 0 ReturnValue(-1) }
        IfCondition EqualTo(ekw, 15) ThenBlock: { CmdList() ReturnValue(0) }
        IfCondition EqualTo(ekw, 16) ThenBlock: { CmdRun() ReturnValue(0) }
        IfCondition EqualTo(ekw, 17) ThenBlock: { CmdNew() ReturnValue(0) }
        IfCondition EqualTo(ekw, 18) ThenBlock: {
            ei = 0
            WhileLoop LessThan(ei, 26) {
                ArraySet(BState.vars_ptr, ei, 0)
                ei = Add(ei, 1)
            }
            ReturnValue(0)
        }
        IfCondition EqualTo(ekw, 19) ThenBlock: {
            C64_ClearOutput()
            ReturnValue(0)
        }
        
        // POKE addr, value
        IfCondition EqualTo(ekw, 26) ThenBlock: {
            poke_addr = PExpr()
            PSkipSpaces()
            // Skip comma
            ch = GetByte(Parser.line_ptr, Parser.pos)
            IfCondition EqualTo(ch, 44) ThenBlock: {
                Parser.pos = Add(Parser.pos, 1)
            }
            poke_val = PExpr()
            C64Math.POKE(poke_addr, poke_val)
            ReturnValue(0)
        }
        
        // SAVE "filename"
        IfCondition EqualTo(ekw, 27) ThenBlock: {
            PSkipSpaces()
            ch = GetByte(Parser.line_ptr, Parser.pos)
            IfCondition EqualTo(ch, 34) ThenBlock: {
                save_filename = PParseStr()
                save_result = C64FileIO.SaveProgram(save_filename, BState.prog_nums_ptr, BState.prog_text_ptr)
                IfCondition EqualTo(save_result, 1) ThenBlock: {
                    C64_Print("SAVED.")
                    C64_NewLine()
                } ElseBlock: {
                    C64_Print("?DEVICE NOT PRESENT ERROR")
                    C64_NewLine()
                }
                Deallocate(save_filename, 0)
            } ElseBlock: {
                C64_Print("?SYNTAX ERROR")
                C64_NewLine()
            }
            ReturnValue(0)
        }
        
        // LOAD "filename"
        IfCondition EqualTo(ekw, 28) ThenBlock: {
            PSkipSpaces()
            ch = GetByte(Parser.line_ptr, Parser.pos)
            IfCondition EqualTo(ch, 34) ThenBlock: {
                load_filename = PParseStr()
                load_result = C64FileIO.LoadProgram(load_filename, BState.prog_nums_ptr, BState.prog_text_ptr)
                IfCondition GreaterEqual(load_result, 0) ThenBlock: {
                    C64_Print("LOADED ")
                    C64_PrintNum(load_result)
                    C64_Print(" LINES.")
                    C64_NewLine()
                } ElseBlock: {
                    C64_Print("?FILE NOT FOUND ERROR")
                    C64_NewLine()
                }
                Deallocate(load_filename, 0)
            } ElseBlock: {
                C64_Print("?SYNTAX ERROR")
                C64_NewLine()
            }
            ReturnValue(0)
        }
        
        // DATA - just skip (processed by READ)
        IfCondition EqualTo(ekw, 40) ThenBlock: {
            Parser.pos = Parser.line_len
            ReturnValue(0)
        }
        
        // READ var, var, ...
        IfCondition EqualTo(ekw, 41) ThenBlock: {
            CmdRead()
            ReturnValue(0)
        }
        
        // RESTORE
        IfCondition EqualTo(ekw, 42) ThenBlock: {
            BState.data_line_idx = 0
            BState.data_pos = 0
            ReturnValue(0)
        }
        
        // ON x GOTO/GOSUB line1, line2, ...
        IfCondition EqualTo(ekw, 43) ThenBlock: {
            ReturnValue(CmdOn())
        }
        
        IfCondition EqualTo(ekw, 0) ThenBlock: {
            Parser.pos = esave
            CmdLet()
        }
        
        ReturnValue(0)
    }
}

// =============================================================================
// EXECUTE LINE
// =============================================================================
Function.ExecLine {
    Input: line: Address
    Body: {
        PSetLine(line)
        
        done = 0
        WhileLoop And(LessThan(Parser.pos, Parser.line_len), EqualTo(done, 0)) {
            result = ExecStmt()
            
            IfCondition EqualTo(result, -1) ThenBlock: { done = 1 }
            IfCondition EqualTo(result, -2) ThenBlock: { done = 1 }
            
            IfCondition EqualTo(done, 0) ThenBlock: {
                PSkipSpaces()
                IfCondition LessThan(Parser.pos, Parser.line_len) ThenBlock: {
                    ch = GetByte(Parser.line_ptr, Parser.pos)
                    IfCondition EqualTo(ch, 58) ThenBlock: {
                        Parser.pos = Add(Parser.pos, 1)
                    } ElseBlock: {
                        done = 1
                    }
                }
            }
        }
    }
}

// =============================================================================
// STORE LINE
// =============================================================================
Function.StoreLine {
    Input: num: Integer
    Input: text: Address
    Body: {
        tlen = StringLength(text)
        bufsize = Add(tlen, 1)
        tcopy = Allocate(bufsize)
        i = 0
        WhileLoop LessThan(i, tlen) {
            ch = GetByte(text, i)
            SetByte(tcopy, i, ch)
            i = Add(i, 1)
        }
        SetByte(tcopy, tlen, 0)
        
        idx = FindLine(num)
        
        IfCondition NotEqual(idx, -1) ThenBlock: {
            old = XArray.XGet(BState.prog_text_ptr, idx)
            Deallocate(old, 0)
            XArray.XSet(BState.prog_text_ptr, idx, tcopy)
        } ElseBlock: {
            count = XArray.XSize(BState.prog_nums_ptr)
            ins = count
            i = 0
            found = 0
            WhileLoop And(LessThan(i, count), EqualTo(found, 0)) {
                n = XArray.XGet(BState.prog_nums_ptr, i)
                IfCondition GreaterThan(n, num) ThenBlock: {
                    ins = i
                    found = 1
                }
                i = Add(i, 1)
            }
            
            XArray.XInsert(BState.prog_nums_ptr, ins, num)
            XArray.XInsert(BState.prog_text_ptr, ins, tcopy)
        }
    }
}

// =============================================================================
// DELETE LINE
// =============================================================================
Function.DeleteLine {
    Input: num: Integer
    Body: {
        idx = FindLine(num)
        IfCondition NotEqual(idx, -1) ThenBlock: {
            txt = XArray.XGet(BState.prog_text_ptr, idx)
            Deallocate(txt, 0)
            XArray.XDelete(BState.prog_nums_ptr, idx)
            XArray.XDelete(BState.prog_text_ptr, idx)
        }
    }
}

// =============================================================================
// PROCESS INPUT
// =============================================================================
Function.ProcessInput {
    Input: inp: Address
    Body: {
        PSetLine(inp)
        PSkipSpaces()
        
        IfCondition EqualTo(Parser.line_len, 0) ThenBlock: {
            ReturnValue(0)
        }
        
        ch = GetByte(Parser.line_ptr, Parser.pos)
        isdig = PIsDigit(ch)
        
        IfCondition EqualTo(isdig, 1) ThenBlock: {
            num = PParseNum()
            PSkipSpaces()
            
            IfCondition GreaterEqual(Parser.pos, Parser.line_len) ThenBlock: {
                DeleteLine(num)
            } ElseBlock: {
                rlen = Subtract(Parser.line_len, Parser.pos)
                bufsize = Add(rlen, 1)
                rest = Allocate(bufsize)
                i = 0
                WhileLoop LessThan(i, rlen) {
                    srcpos = Add(Parser.pos, i)
                    ch = GetByte(inp, srcpos)
                    SetByte(rest, i, ch)
                    i = Add(i, 1)
                }
                SetByte(rest, rlen, 0)
                StoreLine(num, rest)
                Deallocate(rest, 0)
            }
        } ElseBlock: {
            ExecLine(inp)
        }
        
        ReturnValue(0)
    }
}

// =============================================================================
// MAIN
// =============================================================================
SubRoutine.Main {
    // Initialize TUI and C64 screen
    C64_Init()
    BInit()
    
    // Draw header
    C64_DrawHeader()
    
    // Initial cursor position
    Screen.cursor_row = Screen.output_start
    Screen.cursor_col = 1
    
    // Welcome message
    C64_NewLine()
    C64_Print("READY.")
    C64_NewLine()
    
    // Status bar
    C64_DrawStatus(" F1=HELP  ESC=QUIT ")
    
    repl_run = 1
    WhileLoop EqualTo(repl_run, 1) {
        user_inp = C64_ReadLine()
        
        // Check for QUIT
        cmp = StringCompare(user_inp, "QUIT")
        IfCondition EqualTo(cmp, 0) ThenBlock: {
            repl_run = 0
        } ElseBlock: {
            cmp = StringCompare(user_inp, "quit")
            IfCondition EqualTo(cmp, 0) ThenBlock: {
                repl_run = 0
            } ElseBlock: {
                cmp = StringCompare(user_inp, "EXIT")
                IfCondition EqualTo(cmp, 0) ThenBlock: {
                    repl_run = 0
                } ElseBlock: {
                    cmp = StringCompare(user_inp, "exit")
                    IfCondition EqualTo(cmp, 0) ThenBlock: {
                        repl_run = 0
                    } ElseBlock: {
                        ProcessInput(user_inp)
                        C64_Print("READY.")
                        C64_NewLine()
                    }
                }
            }
        }
        
        Deallocate(user_inp, 0)
    }
    
    // Clean shutdown
    C64_Print("GOODBYE!")
    C64_NewLine()
    TUI_Refresh()
    
    C64_Shutdown()
}

RunTask(Main)